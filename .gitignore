# Unity

# This .gitignore file can be placed at the repository root.

# If the Unity project is inside a subdirectory such as AssetManagerTool/,

# the **/ rules below will also ignore Unity generated folders.

.utmp/
*.log

# Unity generated folders

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

**/[Ll]ibrary/
**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/

# Unity cache / temporary files

**/[Mm]emoryCaptures/
**/[Rr]ecordings/
**/[Aa]ssets/[Ss]ceneDependencyCache*
**/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Blender temporary files

*.blend1
*.blend1.meta

# Asset Store Tools

# Uncomment this line if you wish to ignore the asset store tools plugin

# **/[Aa]ssets/AssetStoreTools*

# JetBrains Rider

**/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.idea/

# Visual Studio / VS Code

.vs/
.vscode/

# Gradle

.gradle/

# Autogenerated VS / MD / Consulo solution and project files

ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta files for generated binaries

*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash reports

sysinfo.txt
mono_crash.*

# Builds / packages

*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.zip
*.7z
*.rar

# Crashlytics

crashlytics-build.properties

# TestRunner generated files

InitTestScene*.unity*

# Addressables default ignores

/ServerData
**/ServerData
**/[Aa]ssets/StreamingAssets/aa*
**/[Aa]ssets/AddressableAssetsData/link.xml*
**/[Aa]ssets/Addressables_Temp*
**/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files

**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# OS files

.DS_Store
Thumbs.db
desktop.ini
